      function setPreviewSection(sectionId: string, textId: string, value: string) {
        const section = document.getElementById(sectionId) as HTMLElement;
        const textEl = document.getElementById(textId);
        if (!section || !textEl) return;
        const trimmed = value.trim();
        section.hidden = trimmed.length === 0;
        textEl.textContent = trimmed;
      }

      function updateResumePreview() {
        if (rpName) {
          rpName.textContent = rbFullName.value.trim() || "Your Name";
        }

        if (rpContact) {
          const contactParts = [
            rbEmail.value.trim(),
            rbPhone.value.trim(),
            rbLinkedin.value.trim(),
            rbGithub.value.trim(),
          ].filter(Boolean);
          rpContact.textContent = contactParts.length ? contactParts.join(" | ") : "email@example.com";
        }

        setPreviewSection("rpObjectiveSection", "rpObjective", rbObjective.value);
        setPreviewSection("rpEducationSection", "rpEducation", rbEducation.value);
        setPreviewSection("rpSkillsSection", "rpSkills", rbSkills.value);
        setPreviewSection("rpProjectsSection", "rpProjects", rbProjects.value);
        setPreviewSection("rpCertificationsSection", "rpCertifications", rbCertifications.value);
        setPreviewSection("rpExperienceSection", "rpExperience", rbExperience.value);
        setPreviewSection("rpAchievementsSection", "rpAchievements", rbAchievements.value);
      }

      const resumeBuilderForm = document.getElementById("resumeBuilderForm");
      resumeBuilderForm?.addEventListener("input", updateResumePreview);
      updateResumePreview();
      const resumePreviewEl = document.getElementById("resumePreview");
      const templateButtons = document.querySelectorAll<HTMLButtonElement>(".template-btn");

      function applyTemplate(templateId: string) {
        if (!resumePreviewEl) return;
        resumePreviewEl.classList.remove(
          "template-ats-professional",
          "template-modern",
          "template-minimal",
          "template-executive"
        );
        resumePreviewEl.classList.add(`template-${templateId}`);

        templateButtons.forEach((btn) => {
          btn.classList.toggle("active", btn.dataset.template === templateId);
        });
      }

      templateButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const templateId = btn.dataset.template;
          if (templateId) applyTemplate(templateId);
        });
      });
      function generateResumePdf() {
        const doc = new jsPDF({ unit: "pt", format: "a4" });
        const pageWidth = doc.internal.pageSize.getWidth();
        const pageHeight = doc.internal.pageSize.getHeight();
        const marginX = 40;
        let y = 50;

        function ensureSpace(lineHeight: number) {
          if (y + lineHeight > pageHeight - 40) {
            doc.addPage();
            y = 50;
          }
        }

        function addSectionHeading(text: string) {
          ensureSpace(24);
          doc.setFont("helvetica", "bold");
          doc.setFontSize(12);
          doc.text(text, marginX, y);
          y += 4;
          doc.setDrawColor(26, 26, 26);
          doc.setLineWidth(0.75);
          doc.line(marginX, y, pageWidth - marginX, y);
          y += 14;
        }

        function addBodyText(text: string, size = 10) {
          const trimmed = text.trim();
          if (!trimmed) return;
          doc.setFont("helvetica", "normal");
          doc.setFontSize(size);
          const wrapped = doc.splitTextToSize(trimmed, pageWidth - marginX * 2);
          wrapped.forEach((line: string) => {
            ensureSpace(size + 4);
            doc.text(line, marginX, y);
            y += size + 4;
          });
        }

        const fullName = rbFullName.value.trim() || "Your Name";
        doc.setFont("helvetica", "bold");
        doc.setFontSize(18);
        doc.text(fullName, marginX, y);
        y += 20;

        const contactParts = [
          rbEmail.value.trim(),
          rbPhone.value.trim(),
          rbLinkedin.value.trim(),
          rbGithub.value.trim(),
        ].filter(Boolean);

        if (contactParts.length) {
          doc.setFont("helvetica", "normal");
          doc.setFontSize(10);
          doc.text(contactParts.join(" | "), marginX, y);
          y += 20;
        } else {
          y += 8;
        }

        const sections: { title: string; value: string }[] = [
          { title: "Career Objective", value: rbObjective.value },
          { title: "Education", value: rbEducation.value },
          { title: "Skills", value: rbSkills.value },
          { title: "Work Experience", value: rbExperience.value },
          { title: "Projects", value: rbProjects.value },
          { title: "Certifications", value: rbCertifications.value },
          { title: "Achievements", value: rbAchievements.value },
        ];

        sections.forEach((section) => {
          if (!section.value.trim()) return;
          addSectionHeading(section.title);
          addBodyText(section.value);
          y += 10;
        });

        const fileSafeName = fullName.replace(/[^a-zA-Z0-9]+/g, "-").replace(/^-+|-+$/g, "") || "Resume";
        doc.save(`${fileSafeName}-Resume.pdf`);
      }

      const downloadResumePdfBtn = document.getElementById("downloadResumePdfBtn");
      downloadResumePdfBtn?.addEventListener("click", () => {
        generateResumePdf();
      });
      const printResumeBtn = document.getElementById("printResumeBtn");
      printResumeBtn?.addEventListener("click", () => {
        window.print();
      });

      let extractedResumeText = "";
      let isPdfUploaded = false;
      let selectedRole = "";
      let lastAnalysis: {
        role: string;
        matchPercentage: number;
        readinessScore: number;
        readinessLabel: string;
        currentSkills: string[];
        missingSkills: string[];
        roadmap: Array<{
          week: number;
          topic: string;
          whatToLearn: string;
          howToLearn: string;
          practiceTask: string;
        }> | null;
        projects: Array<{
          title: string;
          difficulty: string;
          skillsUsed: string[];
          expectedOutput: string;
          resumeBullet: string;
        }> | null;
      } | null = null;

      async function extractPdfText(file: File): Promise<string> {
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
        let fullText = "";

        for (let i = 1; i <= pdf.numPages; i++) {
          const page = await pdf.getPage(i);
          const textContent = await page.getTextContent();
          const pageText = textContent.items
            .map((item: any) => ("str" in item ? item.str : ""))
            .join(" ");
          fullText += pageText + "\n\n";
        }

        return fullText.trim();
      }

      async function handleFile(file: File | undefined) {
        errorEl!.textContent = "";
        fileNameEl!.textContent = "";

        if (!file) return;

        if (file.type !== "application/pdf") {
          errorEl!.textContent = "That doesn't look like a PDF. Please upload your resume as a .pdf file so we can read it.";
          debugOutput!.textContent = "No text extracted yet.";
          extractedResumeText = "";
          isPdfUploaded = false;
          return;
        }

        fileNameEl!.textContent = `Reading ${file.name}…`;
        isPdfUploaded = true;
        dropZone?.classList.add("loading");
        try {
          extractedResumeText = await extractPdfText(file);
          debugOutput!.textContent = extractedResumeText || "No text found in this PDF.";
          fileNameEl!.textContent = `Selected file: ${file.name}`;
        } catch (err) {
          errorEl!.textContent = "We couldn't extract text from this PDF — it may be scanned, image-based, or corrupted. Try a PDF exported directly from Word or Google Docs.";
          debugOutput!.textContent = "No text extracted yet.";
          extractedResumeText = "";
          isPdfUploaded = false;
        } finally {
          dropZone?.classList.remove("loading");
        }
      }

      function analyzeResume() {
        const roleSkills = (skills as Record<
          string,
          {
            requiredSkills: string[];
            beginnerSkills: string[];
            intermediateSkills: string[];
            advancedSkills: string[];
          }
        >)[selectedRole];

        if (!roleSkills) {
          validationError!.textContent = "We don't have skill data for this role yet. Please choose a different role.";
          resultsSection.hidden = true;
          roadmapSection.hidden = true;
          projectsSection.hidden = true;
          interviewSection.hidden = true;
          exportPdfWrapper.hidden = true;
          return;
        }

        const allSkills = [
          ...roleSkills.requiredSkills,
          ...roleSkills.beginnerSkills,
          ...roleSkills.intermediateSkills,
          ...roleSkills.advancedSkills,
        ];

        const uniqueSkills = Array.from(new Set(allSkills));
        const resumeTextLower = extractedResumeText.toLowerCase();

        const currentSkills: string[] = [];
        const missingSkills: string[] = [];

        uniqueSkills.forEach((skill) => {
          const keyword = skill.split("(")[0].trim().toLowerCase();
          if (resumeTextLower.includes(keyword)) {
            currentSkills.push(skill);
          } else {
            missingSkills.push(skill);
          }
        });

        const matchPercentage = Math.round(
          (currentSkills.length / uniqueSkills.length) * 100
        );
        matchPercentageText!.textContent = `${matchPercentage}%`;
              matchProgressBar.style.width = `${matchPercentage}%`;
              matchProgressBar.parentElement?.setAttribute("aria-valuenow", String(matchPercentage));
              const hasProjectsKeyword = resumeTextLower.includes("project");
        const hasCertificatesKeyword =
          resumeTextLower.includes("certificate") || resumeTextLower.includes("certification");

        let readinessScore =
          matchPercentage * 0.5 +
          Math.min(currentSkills.length * 3, 20) -
          Math.min(missingSkills.length * 1, 10) +
          (hasProjectsKeyword ? 10 : 0) +
          (hasCertificatesKeyword ? 10 : 0);

        readinessScore = Math.round(Math.min(100, Math.max(0, readinessScore)));

        let readinessLabel = "";
        let readinessClass = "";

        if (readinessScore <= 40) {
          readinessLabel = "Beginner";
          readinessClass = "beginner";
        } else if (readinessScore <= 70) {
          readinessLabel = "Improving";
          readinessClass = "improving";
        } else if (readinessScore <= 85) {
          readinessLabel = "Job Ready Soon";
          readinessClass = "job-ready-soon";
        } else {
          readinessLabel = "Job Ready";
          readinessClass = "job-ready";
        }

        readinessScoreText!.textContent = `${readinessScore}`;
        readinessLabelEl!.textContent = readinessLabel;
        readinessLabelEl!.className = `readiness-label ${readinessClass}`;
              const roleRoadmap = (roadmap as Record<
          string,
          Array<{
            week: number;
            topic: string;
            whatToLearn: string;
            howToLearn: string;
            practiceTask: string;
            resources: Array<{ name: string; type: string; helpsWith: string}>;
          }>
        >)[selectedRole];

        if (roleRoadmap) {
          const missingSkillsLower = missingSkills.map((skill) =>
            skill.split("(")[0].trim().toLowerCase()
          );

          roadmapGrid!.innerHTML = roleRoadmap
            .map((week) => {
              const weekTextLower = `${week.topic} ${week.whatToLearn}`.toLowerCase();
              const isFocusWeek = missingSkillsLower.some((skill) =>
                weekTextLower.includes(skill)
              );
              return `
  <div class="roadmap-card ${isFocusWeek ? "roadmap-card-focus" : ""}">
    <div class="roadmap-week-badge">Week ${week.week}</div>
    <h4>${week.topic}</h4>
    <p><strong>What to learn:</strong> ${week.whatToLearn}</p>
    <p><strong>How to learn:</strong> ${week.howToLearn}</p>
    <p><strong>Practice task:</strong> ${week.practiceTask}</p>

    ${
      week.resources
        ? '<div class="roadmap-resources">' +
          '<p class="roadmap-resources-title"><strong>Free Resources:</strong></p>' +
          '<ul class="roadmap-resources-list">' +
          week.resources
            .map((r) => {
              return (
                '<li class="roadmap-resource-item">' +
                '<span class="resource-name">' + r.name + '</span>' +
                '<span class="resource-type">' + r.type + '</span>' +
                '<span class="resource-helps">' + r.helpsWith + '</span>' +
                '</li>'
              );
            })
            .join("") +
          '</ul>' +
          '</div>'
        : ""
    }
  </div>
`;
            })
            .join("");

          roadmapEmptyState.hidden = true;
roadmapGrid!.hidden = false;
roadmapSection.hidden = false;
} else {
  roadmapGrid!.innerHTML = "";
  roadmapGrid!.hidden = true;
  roadmapEmptyState.hidden = false;
  roadmapSection.hidden = false;
}
        const roleProjects = (projects as Record<
          string,
          Array<{
            title: string;
            difficulty: string;
            skillsUsed: string[];
            expectedOutput: string;
            resumeBullet: string;
          }>
        >)[selectedRole];

        if (roleProjects) {
          projectsGrid!.innerHTML = roleProjects
            .map((project) => {
              const difficultyClass = project.difficulty.toLowerCase();
              return `
  <div class="project-card">
    <div class="project-difficulty-badge ${difficultyClass}">${project.difficulty}</div>
    <h4>${project.title}</h4>
    <p><strong>Skills used:</strong> ${project.skillsUsed.join(", ")}</p>
    <p><strong>Expected output:</strong> ${project.expectedOutput}</p>
    <p class="project-resume-bullet">"${project.resumeBullet}"</p>
  </div>
`;
            })
            .join("");

          projectsSection.hidden = false;
        } else {
          projectsSection.hidden = true;
        }

        const roleInterviewQuestions = (interviewQuestions as Record<
          string,
          {
            beginner: Array<{ question: string; sampleAnswer: string; tips: string; difficulty: string }>;
            intermediate: Array<{ question: string; sampleAnswer: string; tips: string; difficulty: string }>;
            advanced: Array<{ question: string; sampleAnswer: string; tips: string; difficulty: string }>;
          }
        >)[selectedRole];

        if (roleInterviewQuestions) {
          interviewTabs?.querySelectorAll(".interview-tab-btn").forEach((btn) => {
            btn.classList.toggle("active", (btn as HTMLElement).dataset.level === "beginner");
          });
          renderInterviewQuestions(roleInterviewQuestions, "beginner");
          interviewSection.hidden = false;
        } else {
          interviewQuestionsList!.innerHTML = "";
          interviewSection.hidden = true;
        }

        currentSkillsList!.innerHTML =
  currentSkills.map((skill) => `<span class="skill-tag matched">${skill}</span>`).join("") ||
  `<p class="empty-state-message">No matching skills found yet — your roadmap below will help you build them.</p>`;

missingSkillsList!.innerHTML =
  missingSkills.map((skill) => `<span class="skill-tag missing">${skill}</span>`).join("") ||
  `<p class="empty-state-message">No missing skills — you're a full match! 🎉</p>`;

        resultsSection.hidden = false;

        lastAnalysis = {
          role: selectedRole,
          matchPercentage,
          readinessScore,
          readinessLabel,
          currentSkills,
          missingSkills,
          roadmap: roleRoadmap ?? null,
          projects: roleProjects ?? null,
        };
        exportPdfWrapper.hidden = false;
      }
      function generateRoadmapPdf() {
        if (!lastAnalysis) return;

        const doc = new jsPDF({ unit: "pt", format: "a4" });
        const pageWidth = doc.internal.pageSize.getWidth();
        const pageHeight = doc.internal.pageSize.getHeight();
        const marginX = 40;
        let y = 50;

        function ensureSpace(lineHeight: number) {
          if (y + lineHeight > pageHeight - 40) {
            doc.addPage();
            y = 50;
          }
        }

        function addHeading(text: string, size = 14) {
          ensureSpace(size + 10);
          doc.setFont("helvetica", "bold");
          doc.setFontSize(size);
          doc.text(text, marginX, y);
          y += size + 8;
        }

        function addText(text: string, size = 10) {
          doc.setFont("helvetica", "normal");
          doc.setFontSize(size);
          const wrapped = doc.splitTextToSize(text, pageWidth - marginX * 2);
          wrapped.forEach((line: string) => {
            ensureSpace(size + 4);
            doc.text(line, marginX, y);
            y += size + 4;
          });
        }

        doc.setFont("helvetica", "bold");
        doc.setFontSize(20);
        doc.text("ResumeWithCareer", marginX, y);
        y += 30;

        addHeading("Selected Role", 13);
        addText(lastAnalysis.role);
        y += 6;

        addHeading("Match Percentage", 13);
        addText(`${lastAnalysis.matchPercentage}%`);
        y += 6;

        addHeading("Job Readiness Score", 13);
        addText(`${lastAnalysis.readinessScore}/100 (${lastAnalysis.readinessLabel})`);
        y += 6;

        addHeading("Current Skills", 13);
        addText(lastAnalysis.currentSkills.length ? lastAnalysis.currentSkills.join(", ") : "None found");
        y += 6;

        addHeading("Missing Skills", 13);
        addText(lastAnalysis.missingSkills.length ? lastAnalysis.missingSkills.join(", ") : "None - full match!");
        y += 10;

        if (lastAnalysis.roadmap) {
          addHeading("Week-by-Week Roadmap", 15);
          lastAnalysis.roadmap.forEach((week) => {
            ensureSpace(20);
            addHeading(`Week ${week.week}: ${week.topic}`, 12);
            addText(`What to learn: ${week.whatToLearn}`);
            addText(`How to learn: ${week.howToLearn}`);
            addText(`Practice task: ${week.practiceTask}`);
            y += 8;
          });
        }

        if (lastAnalysis.projects) {
          addHeading("Mini Projects", 15);
          lastAnalysis.projects.forEach((project) => {
            ensureSpace(20);
            addHeading(`${project.title} (${project.difficulty})`, 12);
            addText(`Skills used: ${project.skillsUsed.join(", ")}`);
            addText(`Expected output: ${project.expectedOutput}`);
            addText(`Resume bullet: "${project.resumeBullet}"`);
            y += 8;
          });
        }

        doc.save(`ResumeWithCareer-Roadmap-${lastAnalysis.role.replace(/\s+/g, "-")}.pdf`);
      }

      exportPdfBtn?.addEventListener("click", () => {
        generateRoadmapPdf();
      });

      function renderInterviewQuestions(
        roleQuestions: Record<string, Array<{ question: string; sampleAnswer: string; tips: string; difficulty: string }>>,
        level: string
      ) {
        const questions = roleQuestions[level] || [];
        if (!interviewQuestionsList) return;

        if (questions.length === 0) {
          interviewQuestionsList.innerHTML = `<p class="empty-state-message">No ${level} questions available yet.</p>`;
          return;
        }

        interviewQuestionsList.innerHTML = questions
          .map((q, index) => {
            const difficultyClass = q.difficulty.toLowerCase();
            return `
  <details class="interview-question-card">
    <summary class="interview-question-summary">
      <span class="interview-question-number">Q${index + 1}</span>
      <span class="interview-question-text">${q.question}</span>
      <span class="interview-difficulty-badge ${difficultyClass}">${q.difficulty}</span>
    </summary>
    <div class="interview-question-body">
      <p><strong>Sample Answer:</strong> ${q.sampleAnswer}</p>
      <p><strong>Tips:</strong> ${q.tips}</p>
    </div>
  </details>
`;
          })
          .join("");
      }

      interviewTabs?.querySelectorAll(".interview-tab-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const level = (btn as HTMLElement).dataset.level;
          if (!level || !lastAnalysis?.role) return;
          const roleQuestions = (interviewQuestions as Record<string, any>)[lastAnalysis.role];
          if (!roleQuestions) return;

          interviewTabs.querySelectorAll(".interview-tab-btn").forEach((b) => b.classList.toggle("active", b === btn));
          renderInterviewQuestions(roleQuestions, level);
        });
      });

      browseBtn?.addEventListener("click", () => fileInput.click());

      fileInput?.addEventListener("change", () => {
        handleFile(fileInput.files?.[0]);
      });

      dropZone?.addEventListener("dragover", (e) => {
        e.preventDefault();
        dropZone.classList.add("dragover");
      });

      dropZone?.addEventListener("dragleave", () => {
        dropZone.classList.remove("dragover");
      });

      dropZone?.addEventListener("drop", (e) => {
        e.preventDefault();
        dropZone.classList.remove("dragover");
        handleFile(e.dataTransfer?.files[0]);
      });

      roleSelect?.addEventListener("change", () => {
        selectedRole = roleSelect.value;
      });


      analyzeBtn?.addEventListener("click", () => {
        const errors: string[] = [];

        if (!isPdfUploaded) {
          errors.push("Please upload your resume in PDF format before analyzing.");
        }
        if (!selectedRole) {
          errors.push("Please select a career role so we can tailor your analysis.");
        }

        validationError!.textContent = errors.join(" ");

        if (errors.length > 0) {
          resultsSection.hidden = true;
          roadmapSection.hidden = true;
          interviewSection.hidden = true;
          exportPdfWrapper.hidden = true;
          return;
        }

        analyzeResume();
      });
      const tabAnalyzeBtn = document.getElementById("tabAnalyzeBtn");
      const tabCreateBtn = document.getElementById("tabCreateBtn");
      const analyzeTabPanel = document.getElementById("upload") as HTMLElement;
      const createTabPanel = document.getElementById("createResume") as HTMLElement;

      function activateTab(tab: string) {
        const isAnalyze = tab === "analyze";
        analyzeTabPanel.hidden = !isAnalyze;
        createTabPanel.hidden = isAnalyze;
        tabAnalyzeBtn?.classList.toggle("active", isAnalyze);
        tabCreateBtn?.classList.toggle("active", !isAnalyze);
      }

      tabAnalyzeBtn?.addEventListener("click", () => activateTab("analyze"));
      tabCreateBtn?.addEventListener("click", () => activateTab("create"));

    </script>
  </body>
</html>



