    Export Roadmap as PDF
  </button>
</div>
                <details id="debugSection" class="debug-section" hidden>
            <summary>Debug: Extracted Text</summary>
            <pre id="debugOutput" class="debug-output">No text extracted yet.</pre>
          </details>
        </div>
      </section>
      <section id="createResume" class="create-resume-section tab-panel" hidden>
        <div class="container create-resume-inner">
          <h2 class="section-title">Free Resume Builder - Create Your Resume</h2>
          <p class="create-resume-subtitle">Build your resume from scratch using our guided form.</p>
          <div class="template-switcher" id="templateSwitcher">
            <span class="template-switcher-label">Choose a Resume Template:</span>
            <div class="template-options">
              <button type="button" class="template-btn active" data-template="ats-professional">ATS Professional</button>
              <button type="button" class="template-btn" data-template="modern">Modern</button>
              <button type="button" class="template-btn" data-template="minimal">Minimal</button>
              <button type="button" class="template-btn" data-template="executive">Executive</button>
            </div>
          </div>

          <div class="resume-builder-layout">
            <form id="resumeBuilderForm" class="resume-builder-form" onsubmit="return false;">
              <div class="form-group">
                <label for="rbFullName">Full Name</label>
                <input type="text" id="rbFullName" name="fullName" placeholder="e.g. Jane Doe" />
              </div>

              <div class="form-group">
                <label for="rbEmail">Email</label>
                <input type="email" id="rbEmail" name="email" placeholder="e.g. jane@example.com" />
              </div>

              <div class="form-group">
                <label for="rbPhone">Phone</label>
                <input type="tel" id="rbPhone" name="phone" placeholder="e.g. +1 555 123 4567" />
              </div>

              <div class="form-group">
                <label for="rbLinkedin">LinkedIn</label>
                <input type="url" id="rbLinkedin" name="linkedin" placeholder="e.g. https://linkedin.com/in/janedoe" />
              </div>

              <div class="form-group">
                <label for="rbGithub">GitHub</label>
                <input type="url" id="rbGithub" name="github" placeholder="e.g. https://github.com/janedoe" />
              </div>

              <div class="form-group">
                <label for="rbObjective">Career Objective</label>
                <textarea id="rbObjective" name="objective" rows="3" placeholder="A short statement about your career goals..."></textarea>
              </div>

              <div class="form-group">
                <label for="rbEducation">Education</label>
                <textarea id="rbEducation" name="education" rows="3" placeholder="List your education..."></textarea>
              </div>

              <div class="form-group">
                <label for="rbSkills">Skills</label>
                <textarea id="rbSkills" name="skills" rows="3" placeholder="List your skills..."></textarea>
              </div>

              <div class="form-group">
                <label for="rbProjects">Projects</label>
                <textarea id="rbProjects" name="projects" rows="4" placeholder="List your projects..."></textarea>
              </div>

              <div class="form-group">
                <label for="rbCertifications">Certifications</label>
                <textarea id="rbCertifications" name="certifications" rows="3" placeholder="List your certifications..."></textarea>
              </div>

              <div class="form-group">
                <label for="rbExperience">Work Experience</label>
                <textarea id="rbExperience" name="experience" rows="4" placeholder="List your work experience..."></textarea>
              </div>

              <div class="form-group">
                <label for="rbAchievements">Achievements</label>
                <textarea id="rbAchievements" name="achievements" rows="3" placeholder="List your achievements..."></textarea>
              </div>

              <p class="coming-soon-message">Resume Builder coming soon — this form is a placeholder and is not yet functional.</p>
            </form>

            <div class="resume-preview-column">
              <div class="resume-preview-actions">
                <button type="button" id="printResumeBtn" class="btn btn-secondary print-resume-btn">
                  Print Resume
                </button>
                <button type="button" id="downloadResumePdfBtn" class="btn btn-primary download-resume-btn">
                  Download Resume as PDF
                </button>
              </div>

              <div class="resume-preview template-ats-professional" id="resumePreview" aria-live="polite">
                <div class="resume-preview-inner">
                  <h3 class="rp-name" id="rpName">Your Name</h3>
                  <p class="rp-contact" id="rpContact">email@example.com</p>

                  <div class="rp-section" id="rpObjectiveSection" hidden>
                    <h4>Career Objective</h4>
                    <p id="rpObjective"></p>
                  </div>

                  <div class="rp-section" id="rpEducationSection" hidden>
                    <h4>Education</h4>
                    <p id="rpEducation"></p>
                  </div>

                  <div class="rp-section" id="rpSkillsSection" hidden>
                    <h4>Skills</h4>
                    <p id="rpSkills"></p>
                  </div>

                  <div class="rp-section" id="rpProjectsSection" hidden>
                    <h4>Projects</h4>
                    <p id="rpProjects"></p>
                  </div>

                  <div class="rp-section" id="rpCertificationsSection" hidden>
                    <h4>Certifications</h4>
                    <p id="rpCertifications"></p>
                  </div>

                  <div class="rp-section" id="rpExperienceSection" hidden>
                    <h4>Work Experience</h4>
                    <p id="rpExperience"></p>
                  </div>

                  <div class="rp-section" id="rpAchievementsSection" hidden>
                    <h4>Achievements</h4>
                    <p id="rpAchievements"></p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
