const siteTitle = "ResumeWithCareer";
import community from "../data/community.json";
---

<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-83SZZ602QL"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-83SZZ602QL');
</script>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (savedTheme === "dark" || (!savedTheme && prefersDark)) {
        document.documentElement.setAttribute("data-theme", "dark");
      }
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Resume" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Free Resume Builder Online | Build & Analyze Your Resume – ResumeWithCareer</title>
<meta name="description" content="Free resume builder and resume analyzer. Upload your resume to get an instant skill-gap check, choose from professional resume templates, and get a personalized roadmap to land your next job." />
<link rel="canonical" href="https://resumewithcareer.com/" />
<meta name="keywords" content="resume, resume builder, resume format, resume templates, resume template, resume examples, free resume builder, resume tips" />
<meta name="theme-color" content="#2563eb" />

<meta property="og:title" content="Free Resume Builder & Resume Analyzer | ResumeWithCareer" />
<meta property="og:description" content="Build a professional resume with free templates, or upload your resume for an instant skill-gap analysis and personalized career roadmap." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://resumewithcareer.com/" />
<meta property="og:site_name" content="ResumeWithCareer" />
<meta property="og:image" content="https://resumewithcareer.com/og-image.png" />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Free Resume Builder & Resume Analyzer | ResumeWithCareer" />
<meta name="twitter:description" content="Build a resume with free templates or get instant skill-gap analysis and a personalized roadmap." />
<meta name="twitter:image" content="https://resumewithcareer.com/og-image.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "ResumeWithCareer",
      "url": "https://resumewithcareer.com/",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Free resume builder and resume analyzer with skill-gap analysis, resume templates, and personalized career roadmaps.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })}></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How to write a resume?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Start with your contact details, then add a short career objective or summary. Follow with your education, work experience, skills, and projects in reverse-chronological order. Use clear section headings, bullet points, and action verbs, and tailor the content to the job you're applying for so it passes ATS screening.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to make a resume?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Choose an ATS-friendly resume template, fill in your personal details, education, skills, and experience, and keep the formatting simple with standard fonts and clear headings. You can use a free resume builder like ResumeWithCareer to generate a polished resume in minutes without any design skills.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a CV vs resume?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A resume is a concise 1-2 page document summarizing your skills, experience, and education for a specific job application. A CV (Curriculum Vitae) is a longer, more detailed document covering your entire academic and professional history, commonly used for academic, research, or international job applications.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to add resume to LinkedIn?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Log in to LinkedIn, go to your profile, click 'Add profile section' or the 'Open to' button, and select 'Media' under the featured section to upload your resume as a PDF or DOC file. You can also attach your resume directly when applying to jobs through LinkedIn's Easy Apply feature.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How many pages should a resume be?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Most resumes should be one page, especially for early-career professionals or those with less than 10 years of experience. A two-page resume is acceptable for senior professionals with extensive relevant experience, but it should never exceed two pages.</p>"
          }
        }
      ]
    })}></script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">ResumeWithCareer</a>
        <nav class="nav">
          <a href="#createResume">Resume Builder</a>
          <a href="#features">Features</a>
          <a href="#upload">Analyze Resume</a>
          <a href="/about-us">About Us</a>
          <a href="/contact-us">Contact Us</a>
          <button type="button" id="themeToggle" class="theme-toggle" aria-label="Toggle dark mode">🌙</button>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero-inner">
          <h1>Free Resume Builder & Resume Analyzer</h1>
          <p class="subtitle">
            Create, polish, and manage your resume to help you land your next
            opportunity faster.
          </p>
          <div class="cta-buttons">
            <a href="#upload" class="btn btn-primary">Build Your Resume Now</a>
            <a href="#features" class="btn btn-secondary">Explore Features</a>
          </div>
        </div>
      </section>
      <section id="mainTabs" class="main-tabs">
        <div class="container tabs-inner">
          <button type="button" class="tab-btn active" id="tabAnalyzeBtn" data-tab="analyze">Analyze Resume</button>
          <button type="button" class="tab-btn" id="tabCreateBtn" data-tab="create">Create Resume</button>
        </div>
      </section>

      <section id="upload" class="upload-section tab-panel">
        <div class="container upload-inner">
          <h2 class="section-title">Upload Your Resume</h2>
          <p class="upload-subtitle">Upload your resume in PDF format to get started. We check your resume format and content instantly.</p>

          <div id="dropZone" class="upload-box">
            <p class="upload-icon">📄</p>
            <p>Drag &amp; drop your PDF here</p>
            <p class="upload-or">or</p>
            <button type="button" id="browseBtn" class="btn btn-primary">Browse File</button>
            <input
              type="file"
              id="fileInput"
              accept=".pdf,application/pdf"
              hidden
            />
          </div>

          <p id="fileName" class="file-name"></p>
          <p id="errorMessage" class="error-message"></p>

          <div class="role-select-wrapper">
            <label for="roleSelect">Select Career Role</label>
            <select id="roleSelect" class="role-select">
              <option value="" selected disabled>-- Choose a role --</option>
              <option value="Cloud Engineer">Cloud Engineer</option>
              <option value="Frontend Developer">Frontend Developer</option>
              <option value="Backend Developer">Backend Developer</option>
              <option value="Full Stack Developer">Full Stack Developer</option>
              <option value="AI Engineer">AI Engineer</option>
              <option value="ML Engineer">ML Engineer</option>
              <option value="DevOps Engineer">DevOps Engineer</option>
              <option value="Data Analyst">Data Analyst</option>
              <option value="Cyber Security">Cyber Security</option>
              <option value="Software Engineer">Software Engineer</option>
              <option value="UI/UX Designer">UI/UX Designer</option>
              <option value="Mobile App Developer">Mobile App Developer</option>
            </select>
          </div>
          <button type="button" id="analyzeBtn" class="btn btn-primary analyze-btn">Analyze Resume</button>
          <p id="validationError" class="error-message"></p>

           <div id="resultsSection" class="results-section" hidden>
            <h3>Skill Match Results</h3>

            <div class="results-cards">
              <div class="result-card result-card-percentage">
                <h4>Match Percentage</h4>
                <div
                  class="progress-bar-track"
                  role="progressbar"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-valuenow="0"
                  aria-label="Skill match percentage"
                >
                  <div id="matchProgressBar" class="progress-bar-fill"></div>
                </div>
                <span id="matchPercentageText" class="match-percentage-value">0%</span>
              </div>

              <div class="result-card">
                <h4>Current Skills</h4>
                <div id="currentSkillsList" class="skills-tags"></div>
              </div>

              <div class="result-card">
                <h4>Missing Skills</h4>
                <div id="missingSkillsList" class="skills-tags"></div>
              </div>
                        <div class="readiness-card">
  <h4>Job Readiness Score</h4>
  <div class="readiness-score-value">
    <span id="readinessScoreText">0</span><span class="readiness-score-max">/100</span>
  </div>
  <span id="readinessLabel" class="readiness-label"></span>
</div>
            </div>
          </div>
                <div id="roadmapSection" class="roadmap-section" hidden>
  <h3>Your Personalized Roadmap</h3>
  <p id="roadmapEmptyState" class="empty-state-message" hidden>
    A roadmap for this role isn't available yet — we're working on adding it soon!
  </p>
  <div id="roadmapGrid" class="roadmap-grid"></div>
</div>
          <div id="projectsSection" class="projects-section" hidden>
  <h3>Recommended Mini Projects</h3>
  <div id="projectsGrid" class="projects-grid"></div>
</div>
<div id="interviewSection" class="interview-section" hidden>
  <h3>Interview Preparation</h3>
