    <button type="button" class="interview-tab-btn active" data-level="beginner">Beginner</button>
    <button type="button" class="interview-tab-btn" data-level="intermediate">Intermediate</button>
    <button type="button" class="interview-tab-btn" data-level="advanced">Advanced</button>
